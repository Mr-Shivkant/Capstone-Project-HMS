{
  "version": 2,
  "name": "capstone-project-hms",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*.{html,css,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
    }
  ],
  "env": {
    "MONGO_URI": "@MONGO_URI",
    "CLIENT_URL": "@CLIENT_URL"
  }
}
