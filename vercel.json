{
  "version": 2,
  "name": "capstone-project-hms",
  "buildCommand": "cd backend && npm install",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/**/*.{css,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    },
    {
      "src": "^/$",
      "dest": "/frontend/login.html"
    },
    {
      "src": "^/dashboard(.*)$",
      "dest": "/frontend/dashboard.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "MONGO_URI": "@MONGO_URI",
    "CLIENT_URL": "@CLIENT_URL"
  }
}
