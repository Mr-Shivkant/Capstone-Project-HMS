{
  "version": 2,
  "name": "capstone-project-hms",
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "^/$",
      "dest": "/frontend/login.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ]
}
